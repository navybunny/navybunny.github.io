<%- partial('partial/head') %>
<%- partial('partial/header') %>

<main id="main-content">
  <div class="about-container">
    <div class="about-card glass-panel">
      <% if (theme.avatar) { %>
        <img
          src="<%= url_for(theme.avatar) %>"
          alt="<%= __('a11y.avatar') %>"
          class="about-avatar"
          loading="lazy"
        >
      <% } %>

      <h1 class="about-name kinetic-title"><%= config.author %></h1>
      <p class="about-bio"><%= config.description %></p>

      <% if (page.content) { %>
        <div class="about-content">
          <%- page.content %>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- partial('partial/footer') %>
